{
  "name": "subedit",
  "version": "0.1.0",
  "description": "Standalone client-side subtitle editor for SRT, VTT, ASS and SSA: edit cues and timings with a video/waveform preview, byte-preserving your file, all in the browser.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:demo": "npm run assets && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "assets": "node scripts/copy-octopus-assets.mjs && node scripts/copy-libav-assets.mjs",
    "dev": "npm run assets && vite",
    "preview": "vite preview",
    "test": "vitest run",
    "prepare": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "codem-isoboxer": "^0.3.10",
    "mediabunny": "github:hikashop-nicolas/mediabunny#113b0f2",
    "mediaplay": "github:hikashop-nicolas/mediaplay#ccef4ae"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.0"
  }
}
